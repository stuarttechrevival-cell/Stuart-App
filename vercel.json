{
  "version": 2,
  "builds": [
    {
      "src": "api/airtable.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/airtable",
      "dest": "/api/airtable.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
